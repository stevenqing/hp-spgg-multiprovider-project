@book{72bf2cf9895a47e7be9a668a25215110,
title = "Successive approximation for average reward Markov games",
abstract = "This paper considers two-person zero-sum Markov games with finitely many states and actions with the criterion of average reward per unit time. Two special situations are treated and it is shown that in both cases the method of successive approximations yields an e-band for the value of the game as well as stationary e-optimal strategies. In the first case all underlying Markov chains of pure stationary optimal strategies are assumed to be unichained. In the second case it is assumed that the functional equation Uv = v + ge has a solution.",
author = "{Wal, van der}, J.",
year = "1977",
