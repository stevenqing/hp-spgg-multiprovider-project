\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces E2 empirical realisation of Theorem~\ref {thm:hpsmg-plus}(ii)'s two-regime prediction on HP-SPGG (Llama-Maverick backbone, $n = 3$ agents, $10$ seeds, mean $\pm $ SEM). The two curves are not competing algorithms but the two regimes the theorem predicts. \emph  {Upper curve} (light blue): vanilla H-PSMG, which the theorem predicts to incur $\Omega (|\Theta _i|^n H)$ burn-in regret. \emph  {Lower curve} (deep navy): H-PSMG\textsuperscript  {+} (ours, $\beta = 0.25$), which the theorem predicts to cap burn-in regret at $O(H)$. The shaded band measures the predicted gap; per-axis labels give its magnitude. The gap grows from $+0.14$ at $|\Theta _i| = 2$ to $+1.08$ at $|\Theta _i| = 6$, the predicted regime where the burn-in budget is largest and the bonus is most valuable. Mid-range non-monotonicity reflects persona-design specifics together with finite-seed variance.}}{23}{figure.caption.26}\protected@file@percent }
\newlabel{fig:e2-type-scaling}{{4}{23}{E2 empirical realisation of Theorem~\ref {thm:hpsmg-plus}(ii)'s two-regime prediction on HP-SPGG (Llama-Maverick backbone, $n = 3$ agents, $10$ seeds, mean $\pm $ SEM). The two curves are not competing algorithms but the two regimes the theorem predicts. \emph {Upper curve} (light blue): vanilla H-PSMG, which the theorem predicts to incur $\Omega (|\Theta _i|^n H)$ burn-in regret. \emph {Lower curve} (deep navy): H-PSMG\textsuperscript {+} (ours, $\beta = 0.25$), which the theorem predicts to cap burn-in regret at $O(H)$. The shaded band measures the predicted gap; per-axis labels give its magnitude. The gap grows from $+0.14$ at $|\Theta _i| = 2$ to $+1.08$ at $|\Theta _i| = 6$, the predicted regime where the burn-in budget is largest and the bonus is most valuable. Mid-range non-monotonicity reflects persona-design specifics together with finite-seed variance}{figure.caption.26}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {9.2.1}Concordia Pub Coordination}{23}{subsubsection.9.2.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {9.2.2}Concordia Haggling}{23}{subsubsection.9.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Concordia results across both substrates. \emph  {Left:} Pub Coordination, $9$ axes covering $7$ village configurations at $s = 30$ (one of which, \texttt  {capetown}, is also evaluated at $s = 100$) plus one DeepSeek-V3.2 live LLM rollout on \texttt  {london\_mini} at $s = 5$. \emph  {Right:} Haggling, $9$ axes spanning $5$ single-item and $4$ multi-item configurations at $s = 30$. Each axis is per-axis min--max normalised so that the best of the four algorithms on that axis reaches the outer ring and the worst sits near the centre; oracle is shown as a dashed reference polygon and is not always the outer ring because H-PSMG\textsuperscript  {+} can strictly exceed oracle on focal score (see \texttt  {vegbrooke\_stubborn} and the \texttt  {fruitville\_gullible} axes on Haggling). H-PSMG\textsuperscript  {+} (joint proxy) fills nearly the full Pub Coordination polygon and ties or wins on all $9$ Haggling axes; ECON-BNE-mech and A-ToM-1-mech contract toward the centre on most non-trivial configurations; on \texttt  {vegbrooke\_strange}, A-ToM-1-mech catastrophically collapses to the inner ring at focal score $-10$.}}{24}{figure.caption.29}\protected@file@percent }
\newlabel{fig:concordia-main}{{5}{24}{Concordia results across both substrates. \emph {Left:} Pub Coordination, $9$ axes covering $7$ village configurations at $s = 30$ (one of which, \texttt {capetown}, is also evaluated at $s = 100$) plus one DeepSeek-V3.2 live LLM rollout on \texttt {london\_mini} at $s = 5$. \emph {Right:} Haggling, $9$ axes spanning $5$ single-item and $4$ multi-item configurations at $s = 30$. Each axis is per-axis min--max normalised so that the best of the four algorithms on that axis reaches the outer ring and the worst sits near the centre; oracle is shown as a dashed reference polygon and is not always the outer ring because H-PSMG\textsuperscript {+} can strictly exceed oracle on focal score (see \texttt {vegbrooke\_stubborn} and the \texttt {fruitville\_gullible} axes on Haggling). H-PSMG\textsuperscript {+} (joint proxy) fills nearly the full Pub Coordination polygon and ties or wins on all $9$ Haggling axes; ECON-BNE-mech and A-ToM-1-mech contract toward the centre on most non-trivial configurations; on \texttt {vegbrooke\_strange}, A-ToM-1-mech catastrophically collapses to the inner ring at focal score $-10$}{figure.caption.29}{}}
