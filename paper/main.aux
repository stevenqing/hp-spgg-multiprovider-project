\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Cumulative Bayesian regret on HP-SPGG across four LLM backbones ($K{=}20$, $5$ seeds, calibration c19, mean shown with thin error indicators for $\pm \sigma $). Each panel shows the same set of algorithms, grouped into three families by background tint: \emph  {Bayesian type-aware} (blue band, top) including H-PSMG\textsuperscript  {+} and H-PSMG (our methods, bolded labels), MAP-Type-Greedy, and Joint-PSRL; \emph  {LLM coordination} (warm band) including $\mathrm  {llm\_belief}$, ECON-BNE, A-ToM-0, and A-ToM hedge; \emph  {type-agnostic} (gray band, bottom) including PSRL-NoType, Random, and IQL. Numeric values at bar tips show mean regret. The H-PSMG family attains the lowest non-oracle regret on every backbone, separating from the best LLM-coordination baseline by $6$ to $12\times $ and from the best type-agnostic baseline by over $25\times $. The identity of the best LLM-coordination baseline varies across backbones (no single LLM-coordination method dominates), while the H-PSMG family is uniformly best.}}{19}{figure.caption.17}\protected@file@percent }
\newlabel{fig:hp-spgg-cross-model}{{1}{19}{Cumulative Bayesian regret on HP-SPGG across four LLM backbones ($K{=}20$, $5$ seeds, calibration c19, mean shown with thin error indicators for $\pm \sigma $). Each panel shows the same set of algorithms, grouped into three families by background tint: \emph {Bayesian type-aware} (blue band, top) including H-PSMG\textsuperscript {+} and H-PSMG (our methods, bolded labels), MAP-Type-Greedy, and Joint-PSRL; \emph {LLM coordination} (warm band) including $\mathrm {llm\_belief}$, ECON-BNE, A-ToM-0, and A-ToM hedge; \emph {type-agnostic} (gray band, bottom) including PSRL-NoType, Random, and IQL. Numeric values at bar tips show mean regret. The H-PSMG family attains the lowest non-oracle regret on every backbone, separating from the best LLM-coordination baseline by $6$ to $12\times $ and from the best type-agnostic baseline by over $25\times $. The identity of the best LLM-coordination baseline varies across backbones (no single LLM-coordination method dominates), while the H-PSMG family is uniformly best}{figure.caption.17}{}}
