\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces HP-SPGG cumulative Bayesian regret at $K = 20$, $5$ seeds, mean $\pm $ std. H-PSMG family (best of $\{\text  {H-PSMG}, \text  {H-PSMG}^+\}$ across $\beta \in [0, 1.5]$) is the lowest non-oracle entry on every backbone, separating from the best LLM-coordination baseline by $6.3$ to $11.8\times $ and from the best type-agnostic baseline by $27$ to $35\times $. The identity of the best LLM-coordination baseline varies across backbones: \texttt  {llm\_belief} on DeepSeek, A-ToM-0 on GPT-5.4-nano, A-ToM hedge on Kimi-K2.6, and ECON-BNE on Llama-Maverick. ECON-BNE's regret on GPT-5.4-nano ($14.88$) is $3.7\times $ its regret on DeepSeek ($3.99$), reflecting GPT-5.4-nano's reduced capacity to execute ECON's multi-step belief-deliberation prompts.}}{21}{table.caption.22}\protected@file@percent }
\newlabel{tab:hp-spgg-headline}{{2}{21}{HP-SPGG cumulative Bayesian regret at $K = 20$, $5$ seeds, mean $\pm $ std. H-PSMG family (best of $\{\text {H-PSMG}, \text {H-PSMG}^+\}$ across $\beta \in [0, 1.5]$) is the lowest non-oracle entry on every backbone, separating from the best LLM-coordination baseline by $6.3$ to $11.8\times $ and from the best type-agnostic baseline by $27$ to $35\times $. The identity of the best LLM-coordination baseline varies across backbones: \texttt {llm\_belief} on DeepSeek, A-ToM-0 on GPT-5.4-nano, A-ToM hedge on Kimi-K2.6, and ECON-BNE on Llama-Maverick. ECON-BNE's regret on GPT-5.4-nano ($14.88$) is $3.7\times $ its regret on DeepSeek ($3.99$), reflecting GPT-5.4-nano's reduced capacity to execute ECON's multi-step belief-deliberation prompts}{table.caption.22}{}}
