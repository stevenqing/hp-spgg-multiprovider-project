\newlabel{fig:sotopia-results}{{4a}{8}{SOTOPIA-Hard: Partial Transfer Beyond Theoretical Preconditions}{subfigure.4.1}{}}
\newlabel{fig:sotopia-traj}{{4b}{8}{SOTOPIA-Hard: Partial Transfer Beyond Theoretical Preconditions}{subfigure.4.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces SOTOPIA-Hard, three in-scope scenario families where each agent's payoff depends on a private, partner-unobserved parameter inferred from the $6$-turn dialogue: \emph  {craigslist\_bargains} (hidden reservation price, $n{=}80$), \emph  {revenge\_plot} (hidden motive, $n{=}20$), \emph  {donate\_funds} (hidden donor capacity, $n{=}20$). \emph  {(a)} End-of-dialogue focal score. \emph  {(b)} Per-turn trajectory of the same focal score. The remaining eight SOTOPIA-Hard families -- where the persona is common knowledge or does not gate focal payoff -- collapse the type-discrimination signal and are reported in Appendix~\ref {app:sotopia-detail}.}}{8}{figure.caption.14}\protected@file@percent }
\newlabel{fig:sotopia}{{4}{8}{SOTOPIA-Hard, three in-scope scenario families where each agent's payoff depends on a private, partner-unobserved parameter inferred from the $6$-turn dialogue: \emph {craigslist\_bargains} (hidden reservation price, $n{=}80$), \emph {revenge\_plot} (hidden motive, $n{=}20$), \emph {donate\_funds} (hidden donor capacity, $n{=}20$). \emph {(a)} End-of-dialogue focal score. \emph {(b)} Per-turn trajectory of the same focal score. The remaining eight SOTOPIA-Hard families -- where the persona is common knowledge or does not gate focal payoff -- collapse the type-discrimination signal and are reported in Appendix~\ref {app:sotopia-detail}}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {End-of-dialogue ($k{=}6$): mean focal score averaged across four backbones, error bars SEM across episodes. H-PSMG\textsuperscript {+} leads on every family with $\Delta $ from $+0.02$ to $+0.10$ over the best of A-ToM-$1$, ECON-BNE, llm\_belief, llm\_greedy.\label{fig:sotopia-results}}}}{8}{subfigure.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(b)}{\ignorespaces {Per-turn trajectory: judge re-run on transcripts truncated to $k\!\in \!\{1,\dots ,6\}$ utterances; shaded bands SEM. On \emph {revenge\_plot} H-PSMG\textsuperscript {+} climbs monotonically $1.65{\to }2.93$; on the other two families it is the only baseline whose $k{=}6$ score stays above its mid-dialogue level.}}}{8}{subfigure.4.2}\protected@file@percent }
