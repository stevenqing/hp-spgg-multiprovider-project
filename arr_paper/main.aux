\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces HP-SPGG cumulative Bayesian regret at $K{=}20$ across four LLM backbones ($5$ seeds, calibration c19). Three families: \emph  {Bayesian type-aware} (blue), \emph  {LLM-coordination} (warm), \emph  {type-agnostic} (gray). The H-PSMG family attains the lowest non-oracle regret on every backbone, separating from the best LLM-coordination baseline by $6$--$12\times $ and from the best type-agnostic baseline by over $25\times $.}}{5}{figure.caption.6}\protected@file@percent }
\newlabel{fig:hp-spgg-cross-model}{{1}{5}{HP-SPGG cumulative Bayesian regret at $K{=}20$ across four LLM backbones ($5$ seeds, calibration c19). Three families: \emph {Bayesian type-aware} (blue), \emph {LLM-coordination} (warm), \emph {type-agnostic} (gray). The H-PSMG family attains the lowest non-oracle regret on every backbone, separating from the best LLM-coordination baseline by $6$--$12\times $ and from the best type-agnostic baseline by over $25\times $}{figure.caption.6}{}}
