\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces E4 supplement: per-backbone posterior recovery curves $\mu _k^{\Theta ,i}(\theta _i^\star )$ vs.\ episode $k$ on HP-SPGG. The curves display the exponential concentration predicted by Assumption~\ref {ass:TID}, with concentration speed ordered DeepSeek $>$ GPT-5.4-nano $>$ Kimi-K2.6 $>$ Llama-Maverick. This is the underlying mechanism driving the regime structure of Figure~\ref {fig:e1} and panel~(d) of Figure~\ref {fig:e2-e5}.}}{35}{figure.caption.33}\protected@file@percent }
\newlabel{fig:app-e4-prior}{{10}{35}{E4 supplement: per-backbone posterior recovery curves $\mu _k^{\Theta ,i}(\theta _i^\star )$ vs.\ episode $k$ on HP-SPGG. The curves display the exponential concentration predicted by Assumption~\ref {ass:TID}, with concentration speed ordered DeepSeek $>$ GPT-5.4-nano $>$ Kimi-K2.6 $>$ Llama-Maverick. This is the underlying mechanism driving the regime structure of Figure~\ref {fig:e1} and panel~(d) of Figure~\ref {fig:e2-e5}}{figure.caption.33}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces E2 supplement: H-PSMG\textsuperscript  {+} on HP-SPGG c19 matches a privileged analytic-kernel reference within $0.05$ regret across all four backbones (DeepSeek, GPT-5.4-nano, Kimi-K2.6, Llama-Maverick). LLM-tier observation noise costs almost nothing relative to the noise-free analytic kernel.}}{35}{figure.caption.34}\protected@file@percent }
\newlabel{fig:app-e2-native}{{11}{35}{E2 supplement: H-PSMG\textsuperscript {+} on HP-SPGG c19 matches a privileged analytic-kernel reference within $0.05$ regret across all four backbones (DeepSeek, GPT-5.4-nano, Kimi-K2.6, Llama-Maverick). LLM-tier observation noise costs almost nothing relative to the noise-free analytic kernel}{figure.caption.34}{}}
