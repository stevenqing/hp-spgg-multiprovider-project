\citation{zhou2024sotopia}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Concordia results. \emph  {Left:} Pub Coordination, $9$ axes ($7$ village configs at $s{=}30$, one at $s{=}100$, one DeepSeek-V3.2 live LLM rollout at $s{=}5$). \emph  {Right:} Haggling, $9$ axes spanning $5$ single-item and $4$ multi-item configs at $s{=}30$. Each axis is per-axis min--max normalised so the best of four algorithms reaches the outer ring; oracle is dashed and may sit inside the ring because H-PSMG\textsuperscript  {+} can strictly exceed oracle on focal score. H-PSMG\textsuperscript  {+} (joint proxy) fills nearly the full Pub Coordination polygon and wins or ties on every Haggling axis.}}{7}{figure.caption.12}\protected@file@percent }
\newlabel{fig:concordia-main}{{3}{7}{Concordia results. \emph {Left:} Pub Coordination, $9$ axes ($7$ village configs at $s{=}30$, one at $s{=}100$, one DeepSeek-V3.2 live LLM rollout at $s{=}5$). \emph {Right:} Haggling, $9$ axes spanning $5$ single-item and $4$ multi-item configs at $s{=}30$. Each axis is per-axis min--max normalised so the best of four algorithms reaches the outer ring; oracle is dashed and may sit inside the ring because H-PSMG\textsuperscript {+} can strictly exceed oracle on focal score. H-PSMG\textsuperscript {+} (joint proxy) fills nearly the full Pub Coordination polygon and wins or ties on every Haggling axis}{figure.caption.12}{}}
